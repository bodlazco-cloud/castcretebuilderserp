run = "npm run dev"
entrypoint = "src/app/page.tsx"

[nix]
channel = "stable-24_05"

[deployment]
build = ["sh", "-c", "npm install && npm run build && cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static"]
run = ["sh", "-c", "node .next/standalone/server.js"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
