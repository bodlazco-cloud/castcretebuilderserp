# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: https://supabase.com/dashboard/project/_/settings/api

# Supabase (required for Auth, DB, and Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database — use the Supabase "Transaction" pooler URL (port 6543) for server actions
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Public app URL (used in invite emails — change to your Replit/production URL when deployed)
NEXT_PUBLIC_APP_URL=https://your-app-name.replit.app
